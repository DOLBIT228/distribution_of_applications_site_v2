[Unit]
Description=Distribution of Applications Streamlit App
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/distribution_of_applications_site_v2
EnvironmentFile=/opt/distribution_of_applications_site_v2/.env
ExecStart=/opt/distribution_of_applications_site_v2/.venv/bin/streamlit run app.py --server.address 0.0.0.0 --server.port 8501
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
