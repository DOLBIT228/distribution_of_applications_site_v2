[Unit]
Description=Distribution of Applications Web App (Flask)
After=network.target

[Service]
Type=simple
User=www-data
WorkingDirectory=/opt/distribution_of_applications_site_v2
EnvironmentFile=/opt/distribution_of_applications_site_v2/.env
ExecStart=/opt/distribution_of_applications_site_v2/.venv/bin/gunicorn -w 2 -b 0.0.0.0:8000 backend_service:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
